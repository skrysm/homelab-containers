{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended"
	],

	"dependencyDashboard": true,

	"configMigration": true,

	"prHourlyLimit": 0,
	"prConcurrentLimit": 5,

	"labels": ["dependencies"],
	"packageRules": [
		{
			"description": "Group all GitHub Actions updates",
			"matchManagers": ["github-actions"],
			"groupName": "GitHub Actions",
			"groupSlug": "github-actions",
			"automerge": true,
			"labels": ["dependencies", "github-actions"]
		},
		{
			"description": "Group Docker image tag and digest updates",
			"matchDatasources": ["docker"],
			"matchUpdateTypes": ["digest", "patch", "minor"],
			"groupName": "Docker images",
			"groupSlug": "docker-images",
			"automerge": true,
			"labels": ["dependencies", "docker"]
		},
		{
			"description": "Keep Docker major updates separate",
			"matchDatasources": ["docker"],
			"matchUpdateTypes": ["major"],
			"groupName": "Docker major updates",
			"groupSlug": "docker-major",
			"automerge": false,
			"labels": ["dependencies", "docker", "major"]
		}
	]
}
